@article{HARTMANN1975504,
  title    = {Satellite-sized planetesimals and lunar origin},
  journal  = {Icarus},
  volume   = {24},
  number   = {4},
  pages    = {504-515},
  year     = {1975},
  issn     = {0019-1035},
  doi      = {https://doi.org/10.1016/0019-1035(75)90070-6},
  url      = {https://www.sciencedirect.com/science/article/pii/0019103575900706},
  author   = {William K. Hartmann and Donald R. Davis},
  abstract = {Exploratory calculations using accretionary theory are made to demonstrate plausible sizes of second-largest, third-largest, etc., bodies at the close of planet formation in heliocentric orbits near the planets, assuming asteroid-like size distributions at the start of the calculation. Many satellite-sized bodies are found to be available for capture, cratering, or collisional fragmentation. In the case of Earth-sized planets, the models suggest second-largest bodies of 500 to 3000 km radius, and tens of bodies larger than 100 km radius. Many of these interact with the planet before suffering any fragmentation events with each other. Collision of a large body with Earth could eject iron-deficient crust and upper mantle material, forming a cloud of refractory, volatile-poor dust that could form the Moon. Other satellite systems may have been affected by major capture or collision events of chance character.}
}
